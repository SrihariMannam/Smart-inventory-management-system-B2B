# ===== Render Environment Variables =====
# Set these in Render Dashboard > Your Service > Environment

# Server port (Render sets this automatically)
PORT=8080

# H2 Database (in-memory is fine for demo; use file-based for persistence)
# For file-based persistence on Render: jdbc:h2:file:/tmp/inventory_db
SPRING_DATASOURCE_URL=jdbc:h2:mem:inventory_db
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=password

# CORS - Your Vercel frontend URL (no trailing slash)
# Example: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate a secure one: openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# H2 Console (disable in production)
H2_CONSOLE_ENABLED=false
H2_CONSOLE_WEB_ALLOW_OTHERS=false

# SQL Logging (disable in production)
JPA_SHOW_SQL=false
